<UserControl x:Class="LoreVS.UI.LoreChangesControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:toolkit="clr-namespace:Community.VisualStudio.Toolkit;assembly=Community.VisualStudio.Toolkit"
             xmlns:imaging="clr-namespace:Microsoft.VisualStudio.Imaging;assembly=Microsoft.VisualStudio.Imaging"
             toolkit:Themes.UseVsTheme="True"
             mc:Ignorable="d"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DesignHeight="500" d:DesignWidth="320">

    <Grid Margin="8">
        <!-- Shown when the open solution/folder is not under Lore source control. -->
        <TextBlock x:Name="NoRepositoryMessage"
                   Text="This solution or folder is not under Lore source control."
                   TextWrapping="Wrap"
                   VerticalAlignment="Center" HorizontalAlignment="Center"
                   TextAlignment="Center" Opacity="0.7"
                   Visibility="Collapsed" />

        <DockPanel x:Name="RepositoryPanel">
            <!-- Ahead/behind indicator. Branch switch/create/merge lives on the toolbar dropdown. -->
            <TextBlock DockPanel.Dock="Top"
                       Text="{Binding AheadBehindText}"
                       Margin="0,0,0,8" Opacity="0.8" VerticalAlignment="Center" />

            <!-- Commit area -->
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                <TextBox x:Name="MessageBox"
                         Text="{Binding CommitMessage, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         MinHeight="56" MaxHeight="140"
                         VerticalScrollBarVisibility="Auto"
                         IsEnabled="{Binding CanInteract}"
                         ToolTip="Commit message" />

                <CheckBox x:Name="AmendCheck"
                          Content="Amend latest revision"
                          Margin="0,6,0,0"
                          IsChecked="{Binding Amend}"
                          IsEnabled="{Binding CanInteract}" />

                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <Button x:Name="CommitButton" Content="{Binding CommitCaption}"
                            MinWidth="90" Click="OnCommitClick"
                            IsEnabled="{Binding CanCommit}" />
                    <Button x:Name="CommitPushButton" Content="{Binding CommitAndPushCaption}"
                            Margin="6,0,0,0" Click="OnCommitAndPushClick"
                            IsEnabled="{Binding CanCommit}" />
                </StackPanel>
            </StackPanel>

            <!-- Status line -->
            <TextBlock DockPanel.Dock="Bottom" Text="{Binding StatusText}"
                       Margin="0,8,0,0" Opacity="0.8" TextTrimming="CharacterEllipsis" />

            <!-- Changes header with a master select-all checkbox -->
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,4">
                <CheckBox x:Name="SelectAllCheck"
                          IsChecked="{Binding AllSelected, Mode=TwoWay}"
                          IsThreeState="False"
                          VerticalAlignment="Center"
                          IsEnabled="{Binding CanInteract}"
                          ToolTip="Select all files for commit" />
                <TextBlock FontWeight="Bold" Margin="6,0,0,0" VerticalAlignment="Center"
                           Text="{Binding Changes.Count, StringFormat=Changes ({0})}" />
            </StackPanel>

            <!-- Changed files as a folder tree -->
            <ListBox x:Name="ChangesList"
                     ItemsSource="{Binding Nodes}"
                     SelectionMode="Extended"
                     HorizontalContentAlignment="Stretch"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     MouseDoubleClick="OnChangeDoubleClick"
                     ContextMenuOpening="OnContextMenuOpening">
                <ListBox.InputBindings>
                    <KeyBinding Key="Return" Command="{x:Static ApplicationCommands.NotACommand}" />
                </ListBox.InputBindings>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Margin" Value="0,1" />
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ContextMenu>
                    <ContextMenu>
                        <MenuItem x:Name="OpenDiffMenuItem" Header="Open Diff" Click="OnOpenDiffMenu" />
                        <MenuItem Header="Open File" Click="OnOpenFileMenu" />
                        <Separator />
                        <MenuItem Header="Discard Changes..." Click="OnDiscardMenu" />
                    </ContextMenu>
                </ListBox.ContextMenu>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="{Binding RowMargin}" Background="Transparent"
                              ToolTip="{Binding RowToolTip}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0"
                                      IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                      IsThreeState="False"
                                      VerticalAlignment="Center" Margin="0,0,4,0"
                                      ToolTip="Include in commit" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding ExpanderGlyph}"
                                       Visibility="{Binding ExpanderVisibility}"
                                       MouseLeftButtonUp="OnExpanderClick"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       FontSize="10" Opacity="0.8" Cursor="Hand" />
                            <imaging:CrispImage Grid.Column="2"
                                                Moniker="{Binding Icon}"
                                                Width="16" Height="16"
                                                VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" Text="{Binding Name}"
                                       VerticalAlignment="Center" Margin="4,0,0,0"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="4" Text="{Binding StatusBadge}"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center" Margin="8,0,0,0"
                                       ToolTip="{Binding StatusText}" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>
    </Grid>
</UserControl>
