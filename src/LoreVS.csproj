<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net48</TargetFramework>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <UseWPF>true</UseWPF>

    <!-- VSIX settings -->
    <VSSDKBuildToolsAutoSetup>true</VSSDKBuildToolsAutoSetup>
    <VsixDeployOnDebug>true</VsixDeployOnDebug>
    <GeneratePkgDefFile>true</GeneratePkgDefFile>
    <UseCodebase>true</UseCodebase>
  </PropertyGroup>

  <ItemGroup>
    <ProjectCapability Include="CreateVsixContainer" />
  </ItemGroup>

  <!-- Expose internal types (status parser, endpoint, tool locator, ignore file) to the test project. -->
  <ItemGroup>
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleToAttribute">
      <_Parameter1>LoreVS.Tests</_Parameter1>
    </AssemblyAttribute>
  </ItemGroup>

  <!-- Auto-generated files (use Update because SDK auto-includes *.cs) -->
  <ItemGroup>
    <Compile Update="source.extension.cs">
      <AutoGen>True</AutoGen>
      <DesignTime>True</DesignTime>
      <DependentUpon>source.extension.vsixmanifest</DependentUpon>
    </Compile>
    <Compile Update="VSCommandTable.cs">
      <AutoGen>True</AutoGen>
      <DesignTime>True</DesignTime>
      <DependentUpon>VSCommandTable.vsct</DependentUpon>
    </Compile>
  </ItemGroup>

  <!-- VSCT command table -->
  <ItemGroup>
    <AvailableItemName Include="VSCTCompile" />
  </ItemGroup>
  <ItemGroup>
    <None Remove="VSCommandTable.vsct" />
    <VSCTCompile Include="VSCommandTable.vsct">
      <ResourceName>Menus.ctmenu</ResourceName>
      <Generator>VsctGenerator</Generator>
      <LastGenOutput>VSCommandTable.cs</LastGenOutput>
    </VSCTCompile>
  </ItemGroup>

  <!-- VSIX manifest -->
  <ItemGroup>
    <None Update="source.extension.vsixmanifest">
      <SubType>Designer</SubType>
      <Generator>VsixManifestGenerator</Generator>
      <LastGenOutput>source.extension.cs</LastGenOutput>
    </None>
  </ItemGroup>

  <!-- Resources included in VSIX -->
  <ItemGroup>
    <Content Include="..\LICENSE.txt" Link="Resources\LICENSE.txt" />
    <Content Include="Resources\Icon.png">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <IncludeInVSIX>true</IncludeInVSIX>
    </Content>
  </ItemGroup>

  <!-- Embedded resources -->
  <ItemGroup>
    <EmbeddedResource Update="VSPackage.resx" />
  </ItemGroup>

  <!-- Publish the out-of-process .NET 9 Lore worker (framework-dependent win-x64; the .NET runtime is
       supplied by the host - VS 2026 ships .NET 10 and the worker rolls forward to it) and stage it under
       the VSIX 'Worker' subfolder. LoreBrokeredClient launches it from <extension-dir>\Worker\LoreVS.Worker.exe.
       The worker links a few shared source files from this project rather than referencing the assembly,
       so there is no project cycle. -->
  <PropertyGroup>
    <LoreWorkerProject>$(MSBuildProjectDirectory)\..\worker\LoreVS.Worker\LoreVS.Worker.csproj</LoreWorkerProject>
    <LoreWorkerPublishDir>$(MSBuildProjectDirectory)\..\worker\LoreVS.Worker\bin\$(Configuration)\net9.0\win-x64\publish\</LoreWorkerPublishDir>
    <GetVsixSourceItemsDependsOn Condition="'$(SkipLoreWorkerPublish)' != 'true'">$(GetVsixSourceItemsDependsOn);PublishLoreWorker</GetVsixSourceItemsDependsOn>
  </PropertyGroup>

  <Target Name="PublishLoreWorker" Condition="'$(SkipLoreWorkerPublish)' != 'true'">
    <Message Importance="high" Text="Publishing LoreVS.Worker (framework-dependent win-x64) for VSIX packaging..." />
    <Exec Command="dotnet publish &quot;$(LoreWorkerProject)&quot; -c $(Configuration) -r win-x64 --self-contained false -p:SkipLoreWorkerPublish=true" />
    <ItemGroup>
      <_LoreWorkerPublishFiles Include="$(LoreWorkerPublishDir)**\*.*" />
      <VSIXSourceItem Include="@(_LoreWorkerPublishFiles)">
        <VSIXSubPath>Worker\%(RecursiveDir)</VSIXSubPath>
      </VSIXSourceItem>
    </ItemGroup>
  </Target>

  <!-- .NET Framework assemblies not covered by the SDK or NuGet packages.
       WPF assemblies (PresentationCore/PresentationFramework/WindowsBase/System.Xaml)
       are provided implicitly by UseWPF=true. -->
  <ItemGroup>
    <Reference Include="System.ComponentModel.Composition" />
    <Reference Include="System.Design" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Community.VisualStudio.VSCT" Version="16.0.29.14" PrivateAssets="all" />
    <PackageReference Include="Community.VisualStudio.Toolkit.17" Version="17.0.551" ExcludeAssets="Runtime">
      <IncludeAssets>compile; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <!-- JSON-RPC transport to the out-of-process Lore worker. Visual Studio provides StreamJsonRpc
         (and its dependencies) at runtime, so exclude runtime assets to avoid shipping a copy that
         could conflict with the one already loaded in the IDE process. -->
    <PackageReference Include="StreamJsonRpc" Version="2.20.20" ExcludeAssets="Runtime">
      <IncludeAssets>compile; build; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="Microsoft.VSSDK.BuildTools" Version="18.5.40034">
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
  </ItemGroup>

</Project>